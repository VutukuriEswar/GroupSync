# Database (MongoDB Atlas)
MONGO_URL="mongodb+srv://<username>:<password>@<cluster-url>/?appName=<app-name>"
DB_NAME="group_data"

# CORS Configuration (Comma-separated list of allowed origins)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000"

# OpenRouter API (For AI Model)
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# Secret phrase used to encrypt user tokens
JWT_SECRET=your-secret-key-change-in-production-12345